{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.7",
        "laravel/tinker": "^2.10.1",
        "nativephp/desktop": "^2.1",
        "symfony/css-selector": "^8.0",
        "symfony/dom-crawler": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "jbelien/phpstan-sarif-formatter": "^1.2",
        "larastan/larastan": "^3.9",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "vimeo/psalm": "*"
    },
    "autoload": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "native:run": [
            "Composer\\Config::disableProcessTimeout",
            "\"${NATIVEPHP_DEV_PHP_BIN:-/opt/homebrew/opt/php@8.4/bin/php}\" artisan native:run"
        ],
        "native:run:headless": [
            "Composer\\Config::disableProcessTimeout",
            "\"${NATIVEPHP_DEV_PHP_BIN:-/opt/homebrew/opt/php@8.4/bin/php}\" artisan native:run --no-interaction"
        ],
        "native:update": [
            "composer update nativephp/desktop nativephp/php-bin --with-all-dependencies",
            "@php artisan native:install --force --quiet"
        ],
        "docker:build": [
            "docker compose build"
        ],
        "docker:up": [
            "docker compose up -d"
        ],
        "docker:down": [
            "docker compose down"
        ],
        "docker:logs": [
            "docker compose logs -f --tail=200"
        ],
        "docker:restart": [
            "docker compose down",
            "docker compose up -d"
        ],
        "docker:reset": [
            "docker compose down -v --remove-orphans",
            "docker compose up -d --build"
        ],
        "docker:update": [
            "docker compose pull --ignore-pull-failures",
            "docker compose build --pull",
            "docker compose up -d"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan native:install --force --quiet "
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "native:dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -k -c \"#93c5fd,#c4b5fd\" \"\\\"${NATIVEPHP_DEV_PHP_BIN:-/opt/homebrew/opt/php@8.4/bin/php}\\\" artisan native:run --no-interaction\" \"npm run dev\" --names=app,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
